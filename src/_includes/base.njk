<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0F172A" />

  <title>{% block title %}KritRaj Nexera — Websites & n8n Automation | Shaping the Next Era{% endblock %}</title>
  <meta name="description" content="{% block description %}KritRaj Nexera is a boutique digital agency building fast, custom websites and n8n workflow automation for small businesses, startups, and founders.{% endblock %}" />
  <link rel="canonical" href="{% block canonical %}https://kritrajnexera.com/{% endblock %}" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="KritRaj Nexera" />
  <meta property="og:title" content="{% block ogtitle %}KritRaj Nexera — Shaping the Next Era{% endblock %}" />
  <meta property="og:description" content="{% block ogdesc %}Custom websites that earn trust. n8n automation that buys back time. Two crafts, one standard.{% endblock %}" />
  <meta property="og:url" content="{% block ogurl %}https://kritrajnexera.com/{% endblock %}" />
  <meta property="og:image" content="https://kritrajnexera.com/assets/images/og-cover.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_US" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{% block twittertitle %}KritRaj Nexera — Shaping the Next Era{% endblock %}" />
  <meta name="twitter:description" content="{% block twitterdesc %}Custom websites that earn trust. n8n automation that buys back time.{% endblock %}" />
  <meta name="twitter:image" content="https://kritrajnexera.com/assets/images/og-cover.png" />

  <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg" />
  <link rel="manifest" href="/site.webmanifest" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/assets/css/main.css" />
  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">

  {% if robots == "none" %}<meta name="robots" content="noindex, nofollow" />{% endif %}
  {% if robots == "follow" %}<meta name="robots" content="noindex, follow" />{% endif %}

  {% if extrahead %}{{ extrahead | safe }}{% endif %}

  {% if schema %}{{ schema | safe }}{% endif %}
</head>

<body>
  <canvas id="bg-canvas" aria-hidden="true"></canvas>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header" id="site-header">
    <div class="container nav-inner">
      <a href="/" class="brand" aria-label="KritRaj Nexera — home">
        <span class="brand-mark" aria-hidden="true">
          <span class="logo-crop">
            <picture><source srcset="/assets/icons/logo-kr.webp" type="image/webp"><img src="/assets/icons/logo-kr.png" alt="" loading="lazy" /></picture>
          </span>
        </span>
        <span>
          <span class="brand-name">KritRaj <span class="brand-accent">Nexera</span></span>
          <span class="brand-tagline">Shaping The Next Era</span>
        </span>
      </a>

      <nav class="nav-links" aria-label="Primary">
        <a href="/" data-nav="home">Home</a>
        <a href="/services/" data-nav="services">Services</a>
        <a href="/process/" data-nav="process">Process</a>
        <a href="/faq/" data-nav="faq">FAQ</a>
        <a href="/contact/" data-nav="contact">Contact</a>
      </nav>

      <a href="#" class="btn btn-primary nav-cta" data-nav="contact" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/kritrajnexera/30min'}); return false;">Get a Quote</a>

      <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span class="toggle-bar"></span><span class="toggle-bar"></span><span class="toggle-bar"></span>
      </button>
    </div>

    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <nav aria-label="Mobile">
        <a href="/" data-nav="home">Home</a>
        <a href="/services/" data-nav="services">Services</a>
        <a href="/process/" data-nav="process">Process</a>
        <a href="/faq/" data-nav="faq">FAQ</a>
        <a href="/contact/" data-nav="contact">Contact</a>
        <a href="#" class="btn btn-primary mobile-cta" data-nav="contact" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/kritrajnexera/30min'}); return false;">Get a Quote</a>
      </nav>
    </div>
  </header>

  <main id="main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="brand" aria-label="KritRaj Nexera — home">
          <span class="brand-mark" aria-hidden="true">
            <span class="logo-crop">
            <picture><source srcset="/assets/icons/logo-kr.webp" type="image/webp"><img src="/assets/icons/logo-kr.png" alt="" loading="lazy" /></picture>
          </span>
          <span class="brand-name">KritRaj Nexera</span>
        </a>
        <p class="footer-tag">Shaping the Next Era. Custom websites and n8n automation, done with precision.</p>
        <div class="footer-social">
          <a href="https://www.linkedin.com/company/kritrajnexera" aria-label="LinkedIn" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a>
          <a href="https://twitter.com/kritrajnexera" aria-label="Twitter / X" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
          <a href="https://github.com/kritrajnexera" aria-label="GitHub" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg></a>
          <a href="https://www.instagram.com/kritraj.nexera/" aria-label="Instagram" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5.5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="18" cy="6" r="1.2" fill="currentColor"/></svg></a>
        </div>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/process/">Process</a></li>
          <li><a href="/faq/">FAQ</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/services/#websites">Website Development</a></li>
          <li><a href="/services/#automation">n8n Automation</a></li>
          <li><a href="#" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/kritrajnexera/30min'}); return false;">Get a Quote</a></li>
        </ul>
      </div>
      <div class="footer-col footer-news">
        <h4>Get in touch</h4>
        <p>Reach us directly — we reply the same day.</p>
        <form onsubmit="return false;">
          <input type="email" name="email" placeholder="work@email.com" aria-label="Email" />
          <button type="submit">Start a conversation</button>
        </form>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <span id="year">2026</span> KritRaj Nexera. All rights reserved. <a href="/privacy/" class="footer-legal">Privacy Policy</a></p>
    </div>
  </footer>

  <button class="to-top" id="to-top" aria-label="Back to top"><span aria-hidden="true">&uarr;</span></button>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" defer></script>
  <script src="https://assets.calendly.com/assets/external/widget.js" defer></script>
  <script src="/assets/js/script.js" defer></script>
</body>
</html>
